# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aalta?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Meilisearch
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_API_KEY="masterKey"

# AWS (for S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-west-2"
AWS_S3_BUCKET="aalta-documents"

# Application
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-here"

# Scraper settings
SCRAPER_USER_AGENT="AALTA-Bot/1.0 (+https://aalta.org/bot; transparency@aalta.org)"
SCRAPER_RATE_LIMIT_MS="6000"

# Monitoring
SENTRY_DSN=""
AXIOM_TOKEN=""
